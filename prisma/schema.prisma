generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id            Int     @id @default(autoincrement())

  category      String
  name          String
  description   String
  price         String
  image         String

  customizable  Boolean @default(false)
}