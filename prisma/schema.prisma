generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// Users / auth
// -----------------------------------------------------------------------------

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  STAFF
}

model Admin {
  id        Int       @id @default(autoincrement())
  email     String    @unique
  password  String
  name      String?
  role      AdminRole @default(ADMIN)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  password      String?
  name          String?
  phone         String?
  emailVerified DateTime?

  addresses     Address[]
  orders        Order[]
  cart          Cart?
  reviews       Review[]
  wishlistItems WishlistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
}

// NextAuth session table (kept for future DB-session strategy; current setup uses JWT).
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       Int
  expires      DateTime

  createdAt DateTime @default(now())

  @@index([userId])
}

// -----------------------------------------------------------------------------
// Catalog
// -----------------------------------------------------------------------------

model Category {
  id          Int     @id @default(autoincrement())
  name        String
  slug        String  @unique
  description String?
  image       String?

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model Product {
  id Int @id @default(autoincrement())

  categoryId Int
  category   Category @relation(fields: [categoryId], references: [id])

  // Optional link to a Deity catalog entry. When set, the product's NFC tag
  // points at /darshan/<deity.key> and the storefront shows a Smart-NFC panel.
  deityId Int?
  deity   Deity? @relation(fields: [deityId], references: [id])

  name             String
  slug             String @unique
  shortDescription String
  description      String

  price         String
  discountPrice String?

  featured     Boolean @default(false)
  customizable Boolean @default(false)

  stockStatus       String @default("in-stock")
  stock             Int    @default(0)
  lowStockThreshold Int    @default(5)

  whatsappMessage String?

  modelUrl String?

  // Per-product customization schema: which catalog fields are enabled and
  // their admin-set placeholder/required config. Shape: Record<fieldKey,
  // { placeholder?, required? }>. See lib/customization.ts.
  customFields Json?

  images        ProductImage[]
  variants      ProductVariant[]
  reviews       Review[]
  orderItems    OrderItem[]
  cartItems     CartItem[]
  wishlistItems WishlistItem[]

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([slug])
  @@index([categoryId])
  @@index([featured])
  @@index([deityId])
}

model ProductImage {
  id  Int    @id @default(autoincrement())
  url String

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([productId])
}

model ProductVariant {
  id Int @id @default(autoincrement())

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name          String
  sku           String? @unique
  priceModifier Decimal @default(0) @db.Decimal(10, 2)
  stock         Int     @default(0)
  attributes    Json?

  cartItems  CartItem[]
  orderItems OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

// -----------------------------------------------------------------------------
// Cart
// -----------------------------------------------------------------------------

model Cart {
  id Int @id @default(autoincrement())

  userId Int?  @unique
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  sessionId String? @unique

  items CartItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CartItem {
  id Int @id @default(autoincrement())

  cartId Int
  cart   Cart @relation(fields: [cartId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  variantId Int?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  quantity      Int   @default(1)
  customization Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cartId])
}

// -----------------------------------------------------------------------------
// Orders
// -----------------------------------------------------------------------------

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
  // Order placed in error (test/duplicate). Excluded from analytics like
  // CANCELLED/REFUNDED — it is simply absent from analytics' COUNTED_STATUSES.
  BY_MISTAKE
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  RAZORPAY
  WHATSAPP
  COD
}

model Order {
  id          Int    @id @default(autoincrement())
  orderNumber String @unique

  userId Int?
  user   User? @relation(fields: [userId], references: [id])

  customerName  String
  customerEmail String
  customerPhone String

  shippingAddressId Int?
  shippingAddress   Address? @relation("ShippingAddress", fields: [shippingAddressId], references: [id])

  billingAddressId Int?
  billingAddress   Address? @relation("BillingAddress", fields: [billingAddressId], references: [id])

  items OrderItem[]

  subtotal Decimal @db.Decimal(10, 2)
  tax      Decimal @default(0) @db.Decimal(10, 2)
  shipping Decimal @default(0) @db.Decimal(10, 2)
  discount Decimal @default(0) @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)

  discountCodeId Int?
  discountCode   DiscountCode? @relation(fields: [discountCodeId], references: [id])

  status        OrderStatus   @default(PENDING)
  paymentStatus PaymentStatus @default(PENDING)
  paymentMethod PaymentMethod @default(WHATSAPP)

  paymentReference String?
  notes            String?
  internalNotes    String?

  // Shipment tracking. Populated by the admin when an order moves to SHIPPED.
  // `trackingCarrier` is a carrier key from lib/carriers.ts; `trackingUrl` is the
  // resolved customer-facing tracking link (auto-built from the carrier template
  // or an admin-supplied override). See lib/carriers.ts.
  trackingCarrier String?
  trackingNumber  String?
  trackingUrl     String?
  shippedAt       DateTime?

  // Cached live tracking pulled from the shipping aggregator (iThink Logistics).
  // `trackingData` holds the normalized last response (current status + scans),
  // `trackingSyncedAt` gates re-fetching so we don't hit the API on every view.
  // See lib/ithink.ts.
  trackingData     Json?
  trackingSyncedAt DateTime?

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id])

  variantId Int?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  productName String
  unitPrice   Decimal @db.Decimal(10, 2)
  quantity    Int
  subtotal    Decimal @db.Decimal(10, 2)

  customization Json?

  createdAt DateTime @default(now())

  @@index([orderId])
}

// -----------------------------------------------------------------------------
// Addresses, reviews, wishlist, discounts, settings
// -----------------------------------------------------------------------------

model Address {
  id Int @id @default(autoincrement())

  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName   String
  phone      String
  email      String?
  street     String
  city       String
  state      String
  postalCode String
  country    String  @default("IN")
  isDefault  Boolean @default(false)

  shippingOrders Order[] @relation("ShippingAddress")
  billingOrders  Order[] @relation("BillingAddress")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Review {
  id Int @id @default(autoincrement())

  // Either a logged-in User OR a guest identified by email. Guest reviews are
  // validated against the order history before being accepted.
  userId Int?
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  customerEmail String?
  customerName  String?

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  rating  Int
  title   String?
  comment String?

  approved Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerEmail, productId])
  @@index([productId])
}

model WishlistItem {
  id Int @id @default(autoincrement())

  userId Int
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model DiscountCode {
  id Int @id @default(autoincrement())

  code        String       @unique
  description String?
  type        DiscountType
  value       Decimal      @db.Decimal(10, 2)

  minOrderValue Decimal? @db.Decimal(10, 2)
  maxUses       Int?
  usedCount     Int      @default(0)
  perUserLimit  Int?

  startsAt  DateTime?
  expiresAt DateTime?
  active    Boolean   @default(true)

  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([active])
}

// Generic key/value site settings.
model Settings {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Existing lead capture & homepage CMS blocks kept as-is.
model Lead {
  id Int @id @default(autoincrement())

  customerName String
  phone        String
  message      String
  productName  String?
  notes        String?
  status       String  @default("new")

  createdAt DateTime @default(now())
}

model HomepageSection {
  id Int @id @default(autoincrement())

  key      String  @unique
  title    String?
  subtitle String?
  image    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// -----------------------------------------------------------------------------
// Darshan / NFC idols
// -----------------------------------------------------------------------------

// Admin-managed catalog of deities backing the NFC idol experience. Each row is
// tiny: it holds only *references* (YouTube IDs, external PDF URLs) — never
// hosted media — so the DB stays small and any flagged item is a one-row swap.
// Aartis/bhajans/scriptures/specialDays are JSON arrays validated by the Zod
// schemas in lib/validators.ts. See docs / CLAUDE.md "Darshan" notes.
model Deity {
  id Int @id @default(autoincrement())

  key    String  @unique // ASCII slug used in the NFC URL: /darshan/<key>
  active Boolean @default(true)

  nameEn          String
  nameHi          String
  mantra          String
  transliteration String?

  // Closing jaikara/chant spoken at the end of the audio panchang announcement,
  // e.g. "हर हर महादेव" / "Har Har Mahadev". Falls back to the mantra when unset.
  jaikaraHi String?
  jaikaraEn String?

  // [{ labelEn, labelHi, youtubeId, slot:"morning"|"sandhya"|"other", source, license }]
  aartis      Json @default("[]")
  // [{ labelEn, labelHi, youtubeId, source, license }]
  bhajans     Json @default("[]")
  // [{ titleEn, titleHi, lang:"hi"|"sa"|"en", pdfUrl, source, license }]
  scriptures  Json @default("[]")
  // [{ labelEn, labelHi, weekday?, tithi?, festivalDates?:[], note? }]
  specialDays Json @default("[]")

  sortOrder Int @default(0)

  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active])
  @@index([sortOrder])
}
